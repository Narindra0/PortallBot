# ==============================================
# PORTALBOT - FICHIER D'EXEMPLE DES VARIABLES D'ENVIRONNEMENT
# Copiez ce fichier en .env (à la racine) et remplacez les valeurs !
# ==============================================

# ------------------------------
# TELEGRAM BOT (OBLIGATOIRE)
# ------------------------------
# Obtenir un token : Créez un bot avec @BotFather sur Telegram
TELEGRAM_TOKEN=votre_token_bot_ici

# Obtenir votre chat ID : Envoyez un message à @userinfobot
TELEGRAM_CHAT_ID=votre_chat_id_ici

# ------------------------------
# IA GÉNÉRATIVE (OBLIGATOIRE)
# ------------------------------
# Priorité d'utilisation : OpenRouter → Groq → Gemini → Hugging Face
#
# OpenRouter (meilleure gestion de modèles multiples gratuit)
# Créez un compte : https://openrouter.ai
OPENROUTER_API_KEY=votre_cle_openrouter_ici

# Groq (très rapide !)
# Obtenez une clé : https://console.groq.com/keys
GROQ_API_KEY=votre_cle_groq_ici

# Google Gemini (mode fallback si OpenRouter et Groq indisponibles)
# Obtenez une clé : https://aistudio.google.com/app/apikey
GEMINI_API_KEY=votre_cle_gemini_ici

# ------------------------------
# HUGGING FACE API (DÉPRÉCIÉ - FALLBACK)
# ------------------------------
# Utilisé uniquement si OpenRouter et Gemini ne sont pas disponibles
# Obtenez une clé : https://huggingface.co/settings/tokens
HF_API_KEY=votre_cle_hf_ici

# ------------------------------
# BASE DE DONNÉES
# ------------------------------
# Local SQLite (pour développement - par défaut: portalbot.db à la racine)
# LOCAL_DB_PATH=./portalbot.db

# Turso (SQLite cloud - pour staging/production, optionnel)
# Pour base de données persistante : https://turso.tech
# TURSO_DATABASE_URL=libsql://votre-base-USERNAME.turso.io
# TURSO_AUTH_TOKEN=votre_token_turso

# ------------------------------
# MODE DÉPLOIEMENT (OPTIONNEL)
# ------------------------------
# Définit si le navigateur Playwright s'affiche (false) ou non (true)
HEADLESS=false

# ------------------------------
# FIRECRAWL (OPTIONNEL)
# ------------------------------
# Pour scraping avancé (plus performant que BeautifulSoup)
# Obtenez une clé : https://firecrawl.dev
# FIRECRAWL_API_KEY=fc_xxxxx

# ------------------------------
# SMTP EMAIL (OPTIONNEL)
# ------------------------------
# Pour notifications email fallback (si Telegram ne fonctionne pas)
# Pour Gmail, utilisez un "Mot de passe d'application"
# SMTP_EMAIL=votre_email@gmail.com
# SMTP_PASSWORD=votre_mot_de_passe_application
