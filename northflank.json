{
  "$schema": "https://schema.northflank.com/v1/project.json",
  "project": {
    "name": "PortalBot",
    "description": "Bot automatisé pour recherche d'emplois avec notifications Telegram",
    "region": "europe-west"
  },
  "services": [
    {
      "name": "portalbot-bot",
      "type": "deployment",
      "billing": {
        "plan": "micro"
      },
      "deployment": {
        "source": {
          "type": "git",
          "repo": "VOTRE_NOM_UTILISATEUR/VOTRE_REPO",
          "branch": "main",
          "docker": {
            "dockerfilePath": "Dockerfile"
          }
        },
        "ports": [],
        "replicas": 1,
        "resources": {
          "cpu": 0.5,
          "memory": 1024
        },
        "environmentVariables": [
          {
            "name": "TELEGRAM_TOKEN",
            "value": "VOTRE_TELEGRAM_TOKEN"
          },
          {
            "name": "TELEGRAM_CHAT_ID",
            "value": "VOTRE_TELEGRAM_CHAT_ID"
          },
          {
            "name": "GEMINI_API_KEY",
            "value": "VOTRE_GEMINI_API_KEY"
          },
          {
            "name": "OPENROUTER_API_KEY",
            "value": "VOTRE_OPENROUTER_API_KEY"
          },
          {
            "name": "GROQ_API_KEY",
            "value": "VOTRE_GROQ_API_KEY"
          },
          {
            "name": "TURSO_DATABASE_URL",
            "value": "VOTRE_TURSO_DATABASE_URL"
          },
          {
            "name": "TURSO_AUTH_TOKEN",
            "value": "VOTRE_TURSO_AUTH_TOKEN"
          },
          {
            "name": "HEADLESS",
            "value": "true"
          }
        ],
        "healthcheck": null
      }
    }
  ]
}
